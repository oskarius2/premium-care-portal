# Copy this file to .env and fill in your own Supabase project credentials.
# These VITE_-prefixed values are inlined into the client bundle at build time.
# Use the public "anon" key only here — never the service_role key.

VITE_SUPABASE_PROJECT_ID="your-project-id"
VITE_SUPABASE_PUBLISHABLE_KEY="your-anon-key"
VITE_SUPABASE_URL="https://your-project-id.supabase.co"

# Supabase Edge Function secrets are configured in Supabase, not exposed to Vite.
# Supabase normally provides SUPABASE_SERVICE_ROLE_KEY automatically to Edge
# Functions. If the dashboard asks for a custom secret name, use SERVICE_ROLE_KEY.
# SERVICE_ROLE_KEY="your-service-role-key"
# ADMIN_SECRET="your-admin-secret"
# RESEND_API_KEY="your-resend-api-key" # optional, only for confirmation emails
