# Copy this file to .env and fill in your own Supabase project credentials.
# These VITE_-prefixed values are inlined into the client bundle at build time.
# Use the public "anon" key only here — never the service_role key.

VITE_SUPABASE_PROJECT_ID="your-project-id"
VITE_SUPABASE_PUBLISHABLE_KEY="your-anon-key"
VITE_SUPABASE_URL="https://your-project-id.supabase.co"
