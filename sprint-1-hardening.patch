diff --git a/supabase/functions/ical-tokens/index.ts b/supabase/functions/ical-tokens/index.ts
new file mode 100644
index 0000000..6d20132
--- /dev/null
+++ b/supabase/functions/ical-tokens/index.ts
@@ -0,0 +1,144 @@
+import { createClient } from "https://esm.sh/@supabase/supabase-js@2";
+import { handleOptions, jsonResponse } from "../_shared/cors.ts";
+
+/**
+ * ical-tokens — admin-CRUD för per-användare-tokens till iCal-feeden.
+ *
+ * Endpoints:
+ *   GET    /            → lista alla tokens (utan klartext)
+ *   POST   /            → skapa ny token { label } → returnerar { token } EN gång
+ *   DELETE /?id=<uuid>  → återkalla en token (sätter revoked_at)
+ *
+ * Auth: använder kallarens JWT (anon-key + Bearer <user-jwt>) och
+ * verifierar att personen har admin-roll via `has_role()`. RLS-policyn
+ * på `ical_feed_tokens` återskapar samma kontroll på DB-nivå som
+ * defense-in-depth.
+ */
+
+async function sha256Hex(input: string): Promise<string> {
+  const buf = await crypto.subtle.digest(
+    "SHA-256",
+    new TextEncoder().encode(input),
+  );
+  return [...new Uint8Array(buf)]
+    .map((b) => b.toString(16).padStart(2, "0"))
+    .join("");
+}
+
+/** 256 bitar entropi i base64url, utan padding. */
+function generateToken(): string {
+  const bytes = new Uint8Array(32);
+  crypto.getRandomValues(bytes);
+  return btoa(String.fromCharCode(...bytes))
+    .replace(/\+/g, "-")
+    .replace(/\//g, "_")
+    .replace(/=+$/, "");
+}
+
+Deno.serve(async (req) => {
+  if (req.method === "OPTIONS") return handleOptions(req);
+
+  // Verifiera JWT — vi använder kallarens token, inte service role,
+  // så att RLS-policyn "Admins manage ical tokens" faktiskt kontrollerar
+  // behörigheten.
+  const authHeader = req.headers.get("Authorization") ?? "";
+  if (!authHeader.startsWith("Bearer ")) {
+    return jsonResponse(req, { error: "Unauthorized" }, 401);
+  }
+
+  const supabase = createClient(
+    Deno.env.get("SUPABASE_URL")!,
+    Deno.env.get("SUPABASE_ANON_KEY")!,
+    { global: { headers: { Authorization: authHeader } } },
+  );
+
+  // getUser() validerar JWT mot Supabase Auth.
+  const { data: userData, error: userErr } = await supabase.auth.getUser();
+  if (userErr || !userData.user) {
+    return jsonResponse(req, { error: "Unauthorized" }, 401);
+  }
+
+  // Defense-in-depth: dubbelkolla rollen i applikationskoden också.
+  const { data: roleRow } = await supabase
+    .from("user_roles")
+    .select("role")
+    .eq("user_id", userData.user.id)
+    .eq("role", "admin")
+    .maybeSingle();
+  if (!roleRow) {
+    return jsonResponse(req, { error: "Forbidden" }, 403);
+  }
+
+  const url = new URL(req.url);
+
+  try {
+    if (req.method === "GET") {
+      const { data, error } = await supabase
+        .from("ical_feed_tokens")
+        .select("id, label, created_at, last_used_at, revoked_at")
+        .order("created_at", { ascending: false });
+      if (error) {
+        console.error("ical_tokens_list_error", { code: error.code });
+        return jsonResponse(req, { error: "Kunde inte hämta tokens" }, 500);
+      }
+      return jsonResponse(req, { tokens: data ?? [] });
+    }
+
+    if (req.method === "POST") {
+      const body = await req.json().catch(() => ({}));
+      const label = typeof body.label === "string" ? body.label.trim() : "";
+      if (!label || label.length > 80) {
+        return jsonResponse(req, { error: "Etikett krävs (max 80 tecken)" }, 400);
+      }
+
+      const token = generateToken();
+      const tokenHash = await sha256Hex(token);
+
+      const { data, error } = await supabase
+        .from("ical_feed_tokens")
+        .insert({
+          token_hash: tokenHash,
+          label,
+          created_by: userData.user.id,
+        })
+        .select("id, label, created_at")
+        .single();
+
+      if (error || !data) {
+        console.error("ical_tokens_insert_error", { code: error?.code });
+        return jsonResponse(req, { error: "Kunde inte skapa token" }, 500);
+      }
+
+      // Klartext-tokenen returneras EN gång — vi lagrar bara hash.
+      return jsonResponse(req, {
+        id: data.id,
+        label: data.label,
+        created_at: data.created_at,
+        token,
+      });
+    }
+
+    if (req.method === "DELETE") {
+      const id = url.searchParams.get("id");
+      if (!id) return jsonResponse(req, { error: "id krävs" }, 400);
+
+      const { error } = await supabase
+        .from("ical_feed_tokens")
+        .update({ revoked_at: new Date().toISOString() })
+        .eq("id", id)
+        .is("revoked_at", null);
+
+      if (error) {
+        console.error("ical_tokens_revoke_error", { code: error.code });
+        return jsonResponse(req, { error: "Kunde inte återkalla token" }, 500);
+      }
+      return jsonResponse(req, { ok: true });
+    }
+
+    return jsonResponse(req, { error: "Method not allowed" }, 405);
+  } catch (err) {
+    const msg = err instanceof Error ? err.message : "unknown";
+    console.error("ical_tokens_unhandled", { message: msg });
+    return jsonResponse(req, { error: "Något gick fel" }, 500);
+  }
+});
diff --git a/supabase/migrations/20260509000000_no_overlap_constraint.sql b/supabase/migrations/20260509000000_no_overlap_constraint.sql
new file mode 100644
index 0000000..a39c5c0
--- /dev/null
+++ b/supabase/migrations/20260509000000_no_overlap_constraint.sql
@@ -0,0 +1,46 @@
+-- ============================================================
+-- Sprint 1.1 — Förhindra double-bookings på databasnivå
+-- ============================================================
+--
+-- Bakgrund:
+--   Edge functionen `create-booking` gör en SELECT-konflikt-check
+--   följt av en INSERT. Mellan dessa två steg kan en annan transaktion
+--   slinka in och boka samma slot (TOCTOU race condition).
+--
+--   Lösning: en EXCLUDE-constraint som låter Postgres atomiskt
+--   garantera att två icke-avbokade bokningar aldrig överlappar.
+--
+-- Krav:
+--   * btree_gist-tillägget för att kunna jämföra range med &&
+--   * En genererad kolumn `time_range` som beskriver bokningens
+--     tidsfönster i Europe/Stockholm
+--
+-- Förändringen är bakåtkompatibel: befintliga icke-överlappande
+-- bokningar påverkas inte. Om DB:n redan innehåller överlappande
+-- icke-avbokade bokningar måste de saneras innan migrationen körs
+-- (kör staging först!).
+-- ============================================================
+
+create extension if not exists btree_gist;
+
+-- Genererad tidsfönster-kolumn. Tolkar booking_date + start_time/end_time
+-- som lokal tid i Stockholm — vilket är exakt vad UI:t skickar in.
+alter table public.bookings
+  add column if not exists time_range tstzrange
+  generated always as (
+    tstzrange(
+      ((booking_date::text || ' ' || start_time::text)::timestamp at time zone 'Europe/Stockholm'),
+      ((booking_date::text || ' ' || end_time::text)::timestamp   at time zone 'Europe/Stockholm'),
+      '[)'
+    )
+  ) stored;
+
+-- Två icke-avbokade bokningar får aldrig överlappa varandra.
+-- Avbokade bokningar ignoreras helt så att en frigjord tid kan bokas igen.
+alter table public.bookings
+  add constraint bookings_no_overlap
+  exclude using gist (time_range with &&)
+  where (status <> 'cancelled');
+
+comment on constraint bookings_no_overlap on public.bookings is
+  'Förhindrar att två icke-avbokade bokningar överlappar. Vid krock returnerar Postgres SQLSTATE 23P01 (exclusion_violation) — fångas av create-booking och mappas till HTTP 409.';
