diff --git a/supabase/functions/_shared/cors.ts b/supabase/functions/_shared/cors.ts
new file mode 100644
index 0000000..35d751d
--- /dev/null
+++ b/supabase/functions/_shared/cors.ts
@@ -0,0 +1,58 @@
+/**
+ * Centraliserad CORS-hantering för edge functions.
+ *
+ * Skälet till en allowlist istället för "*":
+ *   Edge functionen `create-booking` är ett offentligt skrivande API
+ *   (anon key räcker). Med "*" kan vilken sida som helst anropa det
+ *   och fylla kalendern med skräp eller belasta Resend-kvoten.
+ *
+ *   Vi behåller ändå "Access-Control-Allow-Origin" för förhandsbegärda
+ *   CORS-anrop från godkända origins och returnerar "null" annars så
+ *   browsern blockerar svaret.
+ *
+ * Lägg till nya domäner via secret BRAND_ALLOWED_ORIGINS (kommaseparerad).
+ * Saknas den används default-listan nedan.
+ */
+
+const DEFAULT_ALLOWED = [
+  "https://novumestetik.se",
+  "https://www.novumestetik.se",
+  "http://localhost:8080",
+  "http://localhost:5173",
+];
+
+const extra = (Deno.env.get("BRAND_ALLOWED_ORIGINS") ?? "")
+  .split(",")
+  .map((s) => s.trim())
+  .filter(Boolean);
+
+const ALLOWED = new Set<string>([...DEFAULT_ALLOWED, ...extra]);
+
+export function corsHeaders(req: Request): HeadersInit {
+  const origin = req.headers.get("Origin") ?? "";
+  const allow = ALLOWED.has(origin) ? origin : "null";
+  return {
+    "Access-Control-Allow-Origin": allow,
+    "Vary": "Origin",
+    "Access-Control-Allow-Headers":
+      "authorization, x-client-info, apikey, content-type",
+    "Access-Control-Allow-Methods": "GET, POST, PATCH, DELETE, OPTIONS",
+    "Access-Control-Max-Age": "86400",
+  };
+}
+
+/** Hjälpare för att svara på OPTIONS-preflight. */
+export function handleOptions(req: Request): Response {
+  return new Response("ok", { headers: corsHeaders(req) });
+}
+
+/** Standardiserad JSON-responshjälpare med CORS. */
+export function jsonResponse(req: Request, data: unknown, status = 200): Response {
+  return new Response(JSON.stringify(data), {
+    status,
+    headers: {
+      ...corsHeaders(req),
+      "Content-Type": "application/json",
+    },
+  });
+}
