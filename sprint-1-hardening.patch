+-- ============================================================
+-- Sprint 1.2 — Per-användare iCal-feed-tokens
+-- ============================================================
+--
+-- Bakgrund:
+--   Edge functionen `ical-feed` autentiserade tidigare med en delad
+--   ADMIN_SECRET som klistras in i kalender-klienten som query-param.
+--   Det betyder att tokenen lagras i:
+--     * URL-historik
+--     * HTTP-loggar / referer-headers
+--     * Mellanliggande proxies
+--
+--   En läcka ger evig läsåtkomst till all PII (kundnamn + behandling
+--   + tider) och kan bara stoppas genom att rotera ADMIN_SECRET —
+--   vilket också bryter `admin-bookings`-funktionen.
+--
+-- Lösning:
+--   En tabell med per-användare-tokens där endast SHA-256-hashen
+--   lagras. Nya tokens kan skapas och återkallas individuellt utan
+--   att påverka andra integrationer.
+-- ============================================================
+
+create table public.ical_feed_tokens (
+  id uuid primary key default gen_random_uuid(),
+  -- SHA-256 av tokenen i hex (64 tecken). Klartexten visas EN gång
+  -- för användaren i admin-UI och lagras aldrig i DB:n.
+  token_hash text not null unique,
+  -- Användarvänlig etikett, t.ex. "Min iPhone-kalender" eller "Reception".
+  label text not null,
+  created_by uuid references auth.users(id) on delete set null,
+  created_at timestamptz not null default now(),
+  last_used_at timestamptz,
+  revoked_at timestamptz,
+  constraint ical_feed_tokens_label_not_blank check (length(trim(label)) > 0)
+);
+
+create index idx_ical_tokens_active
+  on public.ical_feed_tokens (token_hash)
+  where revoked_at is null;
+
+alter table public.ical_feed_tokens enable row level security;
+
+-- Endast administratörer ser och hanterar tokens. Andra autentiserade
+-- användare (t.ex. framtida "user"-rollen) får ingenting.
+create policy "Admins manage ical tokens"
+  on public.ical_feed_tokens
+  for all
+  to authenticated
+  using (public.has_role(auth.uid(), 'admin'))
+  with check (public.has_role(auth.uid(), 'admin'));
+
+comment on table public.ical_feed_tokens is
+  'Per-användare-tokens för ical-feed. Klartext visas EN gång vid skapande, sedan endast hash. Återkalla via UPDATE … SET revoked_at = now().';
